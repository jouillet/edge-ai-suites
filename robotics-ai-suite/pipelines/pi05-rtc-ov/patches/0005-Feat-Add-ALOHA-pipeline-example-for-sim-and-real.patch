+import argparse
+
+import torch
+import time
+import threading
+import logging
+import math
+import traceback
+import sys
+import matplotlib.pyplot as plt
+from pathlib import Path
+import numpy as np
+import json
+import pandas as pd
+from threading import Event, Thread
+
+from robot_interfaces import AlohaRobot, MujocoAlohaRobot, RobotWrapper
+
+from lerobot.policies.factory import make_pre_post_processors, _get_policy_cls_from_policy_name
+from lerobot.configs.policies import PreTrainedConfig
+from lerobot.policies.pi05.configuration_pi05 import OVConfig
+from lerobot.policies.rtc.action_queue import ActionQueue
+from lerobot.policies.rtc.configuration_rtc import RTCConfig
+from lerobot.policies.rtc.latency_tracker import LatencyTracker
+
+# Configure logging
+# Force reconfiguration to ensure we see output
+logging.basicConfig(
+    level=logging.INFO,
+    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
+    handlers=[
+        logging.StreamHandler(sys.stdout)
+    ],
+    force=True
+)
+logger = logging.getLogger(__name__)
+logger.setLevel(logging.INFO)
+
+class LocalDatasetMetadata:
+    def __init__(self, dataset_path):
+        self.root = Path(dataset_path)
+        self._load_meta()
+
+    def _load_meta(self):
+        info_path = self.root / "meta/info.json"
+        stats_path = self.root / "meta/stats.json"
+        tasks_path_parquet = self.root / "meta/tasks.parquet"
+        
+        if not info_path.exists():
+            raise FileNotFoundError(f"Info file not found at {info_path}")
+        if not stats_path.exists():
+            raise FileNotFoundError(f"Stats file not found at {stats_path}")
+            
+        with open(info_path, 'r') as f:
+            self.info = json.load(f)
+            
+        with open(stats_path, 'r') as f:
+            self.stats = json.load(f)
+
+        self.tasks = []
+        if tasks_path_parquet.exists():
+             try:
+                 df = pd.read_parquet(tasks_path_parquet)
+                 # If the parquet file has a custom index (e.g. task description string), reset it to preserve data
+                 if not isinstance(df.index, pd.RangeIndex):
+                     df.reset_index(inplace=True)
+                 self.tasks = df.to_dict(orient="records")
+             except Exception as e:
+                 logger.warning(f"Failed to load tasks from {tasks_path_parquet}: {e}")
+        else:
+             logger.warning(f"Tasks file not found at {tasks_path_parquet}")
+
+    @property
+    def fps(self):
+        return self.info.get("fps", 30)
+
+def get_actions(
+    policy,
+    robot: RobotWrapper,
+    action_queue: ActionQueue,
+    shutdown_event: Event,
+    fps: float,
+    rtc_enabled: bool,
+    preprocessor,
+    postprocessor,
+    ready_event: Event,
+    start_execution_event: Event,
+    actor_done_event: Event,
+    min_queue_size_before_refill: int = 30,
+    device: str = "cpu",
+    task_description: str = "Do something",
+    log_data: dict = None
+):
+    try:
+        ready_event.wait()
+        latency_tracker = LatencyTracker()
+        time_per_chunk = 1.0 / fps
+        
+        # Determine threshold
+        get_actions_threshold = min_queue_size_before_refill
+        if not rtc_enabled:
+            get_actions_threshold = 0
+
+        while not shutdown_event.is_set():
+            if action_queue.qsize() <= get_actions_threshold:
+                # 1. Prepare for inference
+                current_time = time.perf_counter()
+                action_index_before_inference = action_queue.get_action_index()
+                prev_actions = action_queue.get_left_over()
+                prev_actions = prev_actions.unsqueeze(0) if prev_actions is not None else None
+
+                if rtc_enabled:
+                    inference_latency = latency_tracker.max()
+                    inference_delay = math.ceil(inference_latency / time_per_chunk)
+                    if inference_delay == 0 and start_execution_event.is_set():
+                        inference_delay = 10  # Ensure at least 10 chunk delay
+                else:
+                    inference_delay = 0
+
+                # 2. Capture Observation
+                real_obs = robot.get_observation(render_image=True)
+                
+                # 3. Process Observation (Using preprocessor)
+                batch = {}
+                
+                # Image Mapping
+                if 'images' in real_obs:
+                    # Figure out which image feature keys this checkpoint expects
+                    cfg = getattr(policy, "config", None)
+                    image_feature_keys = set(getattr(cfg, "image_features", {}).keys()) if cfg is not None else set()
+
+                    for key, img in real_obs['images'].items():
+                        policy_key = None
+
+                        # Map high camera
+                        if key == 'camera_high':
+                            if "observation.images.cam_high" in image_feature_keys:
+                                policy_key = "observation.images.cam_high"
+                            elif "observation.images.top" in image_feature_keys:
+                                policy_key = "observation.images.top"
+
+                        # Map low/angle camera
+                        elif key == 'camera_low':
+                            if "observation.images.cam_low" in image_feature_keys:
+                                policy_key = "observation.images.cam_low"
+                            elif "observation.images.top" in image_feature_keys and "observation.images.cam_high" not in image_feature_keys:
+                                # Fallback: some configs only have a single "top" camera
+                                policy_key = "observation.images.top"
+
+                        # Map wrist cameras
+                        elif key == 'camera_wrist_left':
+                            if "observation.images.cam_left_wrist" in image_feature_keys:
+                                policy_key = "observation.images.cam_left_wrist"
+                            elif "observation.images.left_wrist" in image_feature_keys:
+                                policy_key = "observation.images.left_wrist"
+
+                        elif key == 'camera_wrist_right':
+                            if "observation.images.cam_right_wrist" in image_feature_keys:
+                                policy_key = "observation.images.cam_right_wrist"
+                            elif "observation.images.right_wrist" in image_feature_keys:
+                                policy_key = "observation.images.right_wrist"
+
+                        # As a very last resort, if we have image features but no specific match,
+                        # map this camera to the first available feature to avoid an empty batch.
+                        if policy_key is None and image_feature_keys:
+                            # Choose deterministically to avoid nondeterministic set iteration order
+                            policy_key = sorted(image_feature_keys)[0]
+
+                        if policy_key is not None:
+                            if img.strides[0] < 0 or img.strides[1] < 0 or img.strides[2] < 0:
+                                img = img.copy()
+                            # Preprocessors usually expect float [0,1] tensors on device
+                            img_tensor = torch.from_numpy(img).float() / 255.0
+                            img_tensor = img_tensor.permute(2, 0, 1).unsqueeze(0).to(device)  # [B, C, H, W]
+                            batch[policy_key] = img_tensor
+
+                # State Mapping
+                if 'qpos' in real_obs:
+                     qpos = real_obs['qpos']
+                     state_tensor = torch.from_numpy(qpos).float().unsqueeze(0).to(device) # [B, D]
+                     batch["observation.state"] = state_tensor
+                
+                # Task Mapping
+                batch["task"] = [task_description]
+
+                # Run Preprocessor
+                if preprocessor:
+                    batch = preprocessor(batch)
+
+                # 4. Run Inference
+                with torch.no_grad():
+                    inference_start_time = time.perf_counter()
+                    if rtc_enabled:
+                        # Apply prev_chunk_left_over correction
+                        actions = policy.predict_action_chunk(batch, prev_chunk_left_over=prev_actions, inference_delay=inference_delay, execution_horizon=policy.config.rtc_config.execution_horizon)
+                    else:
+                        actions = policy.predict_action_chunk(batch)
+                    dt = time.perf_counter() - inference_start_time
+                    latency_tracker.add(dt)
+                    logger.debug(f"Inference time: {dt*1000:.2f} ms")
+
+                # Capture raw actions for RTC loop (Normalized)
+                original_actions = actions.clone()
+
+                # Run Postprocessor
+                if postprocessor:
+                    actions = postprocessor(actions)
+
+                # 5. Post-process Actions
+                # The postprocessor should handle unnormalization.
+                # 'actions' is now in the original action space but might still have batch dim [B, T, D]
+                
+                processed_actions = actions
+                
+                # Squeeze batch dimension if present (assuming BS=1)
+                if original_actions.ndim == 3 and original_actions.shape[0] == 1:
+                    original_actions = original_actions.squeeze(0)
+                if processed_actions.ndim == 3 and processed_actions.shape[0] == 1:
+                    processed_actions = processed_actions.squeeze(0)
+                
+                if log_data is not None:
+                    log_data['chunks'].append({
+                        'time': time.time(),
+                        # processed_actions is already squeezed and on device, move to cpu numpy
+                        'action': processed_actions.cpu().numpy(),
+                        'latency': dt
+                    })
+
+                action_queue.merge(original_actions, processed_actions, inference_delay, action_index_before_inference)
+                
+                if not start_execution_event.is_set():
+                    start_execution_event.set()
+                    # Reset tracker to avoid using compilation time as latency for next steps
+                    latency_tracker.reset()
+
+            else:
+                 time.sleep(0.001)
+
+        logger.info("[GET_ACTIONS] Thread shutting down")
+        
+    except Exception as e:
+        logger.error(f"[GET_ACTIONS] Exception: {e}")
+        traceback.print_exc()
+        shutdown_event.set()
+    finally:
+        # Ensure the MuJoCo/EGL context is released from the same thread that
+        # performed rendering. Wait for actor to stop stepping before closing.
+        try:
+            actor_done_event.wait(timeout=2.0)
+        except Exception:
+            pass
+        try:
+            robot.close()
+        except Exception:
+            logger.exception("[GET_ACTIONS] Failed to close env during shutdown")
+
+def actor_control(
+    robot: RobotWrapper,
+    action_queue: ActionQueue,
+    shutdown_event: Event,
+    fps: float,
+    ready_event: Event,
+    start_execution_event: Event,
+    actor_done_event: Event,
+    episode_results: list = None,
+    log_data: dict = None,
+    max_steps: int = 400
+):
+    try:
+        robot.reset()
+        ready_event.set()
+        
+        start_execution_event.wait()
+        
+        action_interval = 1.0 / fps
+        max_reward = 0
+        steps_executed = 0
+        
+        while not shutdown_event.is_set():
+            start_time = time.perf_counter()
+            
+            action = action_queue.get()
+            
+            if action is not None:
+                if log_data is not None:
+                    # Capture state for logging
+                    try:
+                        obs = robot.get_observation(render_image=False)
+                        if 'qpos' in obs:
+                            action_to_log = action
+                            if isinstance(action_to_log, torch.Tensor):
+                                action_to_log = action_to_log.detach().cpu().numpy()
+                            log_data['steps'].append({
+                                'time': time.time(),
+                                'state': obs['qpos'],
+                                'action': action_to_log
+                            })
+                    except Exception as e:
+                        pass # Don't crash control loop for logging
+
+                reward = robot.send_action(action.float())
+                if reward is not None:
+                    max_reward = max(max_reward, reward)
+                    steps_executed += 1
+                    if steps_executed >= max_steps:
+                        logger.info(f"[ACTOR] Max steps {max_steps} reached.")
+                        shutdown_event.set()
+                        break
+            
+            dt_s = time.perf_counter() - start_time
+            time.sleep(max(0, (action_interval - dt_s) - 0.001))
+            
+        if episode_results is not None:
+            episode_results.append(max_reward)
+
+        logger.info("[ACTOR] Thread shutting down")
+    except Exception as e:
+        logger.error(f"[ACTOR] Exception: {e}")
+        shutdown_event.set()
+    finally:
+        # Signal that stepping is finished; env teardown happens in get_actions.
+        try:
+            actor_done_event.set()
+        except Exception:
+            pass
+
+
+import os
+
+def save_trajectory_plots(log_data, path, episode_idx, fps=50.0):
+    if not log_data or not log_data.get('steps'):
+        logger.warning(f"No step data to plot for episode {episode_idx}")
+        return
+
+    try:
+        # User requested to overwrite if path exists (even if it's a file)
+        if os.path.exists(path) and not os.path.isdir(path):
+            logger.warning(f"Path {path} exists but is not a directory. Removing it to create output directory.")
+            os.remove(path)
+
+        os.makedirs(path, exist_ok=True)
+        
+        steps = log_data['steps']
+        chunks = log_data.get('chunks', [])
+
+        # Convert to numpy
+        times = np.array([s['time'] for s in steps])
+        if len(times) == 0: return
+        start_time = times[0]
+        times = times - start_time
+        
+        states = np.array([s['state'] for s in steps])
+        actions = np.array([s['action'] for s in steps])
+        
+        # Determine dimensions
+        action_dim = actions.shape[1]
+        
+        fig, axes = plt.subplots(nrows=action_dim, ncols=1, figsize=(10, 4 * action_dim), sharex=True)
+        if action_dim == 1: axes = [axes]
+        
+        fig.suptitle(f'Episode {episode_idx} Trajectory', fontsize=16)
+
+        dt = 1.0 / fps
+
+
+        chunk_colors = ['red', 'orange']
+        for dim in range(action_dim):
+            ax = axes[dim]
+            # Plot State
+            ax.plot(times, states[:, dim], label='State', color='green', linewidth=1.5)
+            # Plot Executed Command
+            ax.plot(times, actions[:, dim], label='Command', color='blue', linestyle='--', linewidth=1.5)
+
+            # Plot Chunks as alternating colored points
+            for i, chunk in enumerate(chunks):
+                chunk_time = chunk['time'] - start_time
+                if i > 0:
+                    chunk_time = chunk_time - chunk['latency']
+                chunk_act = chunk['action']
+                # Ensure chunk_act is [T, D]
+                if chunk_act.ndim == 1:
+                    chunk_act = chunk_act[None, :]
+                chunk_len = chunk_act.shape[0]
+                t_chunk = np.linspace(chunk_time, chunk_time + (chunk_len-1) * dt, chunk_len)
+                color = chunk_colors[i % 2]
+                # Plot each action point as a scatter dot
+                ax.scatter(t_chunk, chunk_act[:, dim], color=color, alpha=0.5, s=8)
+
+            ax.set_ylabel(f'Dim {dim}')
+            if dim == 0:
+                ax.legend()
+            
+        plt.xlabel('Time (s)')
+        # Reserve space for suptitle to avoid squeezing subplots
+        fig.tight_layout(rect=[0, 0, 1, 0.96])
+        plot_file = os.path.join(path, f'episode_{episode_idx}_traj.png')
+        
+        if os.path.exists(plot_file):
+            logger.info(f"Overwriting existing trajectory plot: {plot_file}")
+            
+        plt.savefig(plot_file)
+        plt.close(fig)
+        logger.info(f"Saved trajectory plot to {plot_file}")
+        
+    except Exception as e:
+        logger.error(f"Failed to plot trajectory: {e}")
+        traceback.print_exc()
+
+def main():
+    parser = argparse.ArgumentParser(description="Eval Aloha Pipeline with RTC support")
+    parser.add_argument("--pretrained_model_path", type=str, default="lerobot/pi05_base", help="Path to the pretrained model")
+    parser.add_argument("--dataset_path", type=str, default=None, help="Local path to dataset (optional). Used to load meta/info.json, meta/tasks.parquet, etc.")
+    parser.add_argument("--stats_path", type=str, default=None, help="Path to dataset stats.json (optional).")
+    parser.add_argument("--num_episodes", type=int, default=1, help="Number of trajectories/episodes to run")
+    parser.add_argument("--max_steps", type=int, default=400, help="Max steps per episode")
+    parser.add_argument("--robot_type", type=str, default="mujoco_aloha", help="Robot type (mujoco_aloha, real_aloha)")
+    parser.add_argument("--task", type=str, default="sim_transfer_cube", help="Task name (e.g. sim_transfer_cube, sim_insertion)")
+    
+    # RTC Args
+    parser.add_argument("--rtc_enabled", action="store_true", help="Enable Real-Time Chunking")
+    parser.add_argument("--rtc_horizon", type=int, default=30, help="RTC Execution Horizon")
+    parser.add_argument("--plot", action="store_true", help="Enable visualization")
+    parser.add_argument("--fps", type=float, default=50.0, help="Control Frequency (Hz)")
+    parser.add_argument("--save_traj", action="store_true", help="Save trajectory data and plots")
+    parser.add_argument("--save_traj_path", type=str, default="trajectory_plots", help="Path to save trajectory plots")
+    # OpenVINO Args
+    parser.add_argument("--use_ov", action="store_true", help="Use OpenVINO model for inference")
+    parser.add_argument("--ov_model_path", type=str, default="pi05_lerobot_ov_ir_INT8", help="Path to OpenVINO model")
+    parser.add_argument("--ov_device", type=str, default="GPU.0", help="Device to use for OpenVINO inference (e.g. CPU, GPU)")
+    
+    args = parser.parse_args()
+    
+    logger.info("Arguments parsed successfully.")
+
+    # Load dataset stats.json independently of dataset metadata.
+    stats = None
+    stats_path = Path(args.stats_path).expanduser() if args.stats_path else None
+    if stats_path is None:
+        stats_path = Path(args.pretrained_model_path) / "stats.json"
+
+    if stats_path is not None and stats_path.exists():
+        try:
+            logger.info(f"Loading stats.json from {stats_path}")
+            with open(stats_path, "r") as f:
+                stats = json.load(f)
+        except Exception as e:
+            logger.warning(f"Failed to load stats.json from {stats_path}: {e}. Will attempt to load from dataset metadata if available.")
+            stats = None
+
+    # Load dataset metadata (optional)
+    ds_meta = None
+    if args.dataset_path:
+        try:
+            logger.info(f"Attempting to load dataset metadata from {args.dataset_path}")
+            ds_meta = LocalDatasetMetadata(args.dataset_path)
+            logger.info("Dataset metadata loaded successfully.")
+        except Exception as e:
+            logger.warning(f"Could not load local dataset metadata: {e}. Proceeding without it.")
+            ds_meta = None
+
+    # Load Policy
+    logger.info(f"Loading policy from {args.pretrained_model_path}...")
+    
+    # FIX: Handle extra keys in config that cause draccus to fail (e.g. deprecated params)
+    config_path = Path(args.pretrained_model_path) / "config.json"
+    if config_path.exists():
+        logger.info("Found config.json, checking for sanitation...")
+        import tempfile
+        with open(config_path, "r") as f:
+            cfg_dict = json.load(f)
+        
+        invalid_keys = ["use_peft", "freeze_vision_encoder", "train_expert_only", "gradient_checkpointing"]
+        dirty = False
+        for k in invalid_keys:
+            if k in cfg_dict:
+                del cfg_dict[k]
+                dirty = True
+                
+        if dirty:
+            logger.info(f"Sanitizing config: removed deprecated keys {invalid_keys}")
+            with tempfile.TemporaryDirectory() as temp_dir:
+                temp_config_path = Path(temp_dir) / "config.json"
+                with open(temp_config_path, "w") as f:
+                    json.dump(cfg_dict, f)
+                policy_cfg = PreTrainedConfig.from_pretrained(temp_dir)
+        else:
+             policy_cfg = PreTrainedConfig.from_pretrained(args.pretrained_model_path)
+    else:
+        policy_cfg = PreTrainedConfig.from_pretrained(args.pretrained_model_path)
+    
+    logger.info(f"Policy config loaded: {policy_cfg}")
+
+    # Configure RTC
+    rtc_config = RTCConfig(
+        enabled=args.rtc_enabled,
+        execution_horizon=args.rtc_horizon
+    )
+    policy_cfg.rtc_config = rtc_config
+
+    # If dataset metadata exists and explicit stats weren't provided, allow it to supply stats.
+    if stats is None and ds_meta is not None:
+        stats = getattr(ds_meta, "stats", None)
+    
+    # For Pi0.5 or others, bypass make_policy to avoid strict ds_meta requirement
+    policy_cls = _get_policy_cls_from_policy_name(policy_cfg.type)
+    logger.info(f"Initializing policy class: {policy_cls}")
+    
+    # Instantiate PyTorch policy (needed for preprocessing logic and config)
+    if args.use_ov:
+        ov_config = OVConfig(model_dir=args.ov_model_path, device=args.ov_device)
+        policy = policy_cls(config=policy_cfg, ov_config=ov_config)
+    else: 
+        policy = policy_cls.from_pretrained(args.pretrained_model_path, config=policy_cfg, dataset_stats=stats)
+    device = policy.device if hasattr(policy, 'device') else "cpu"
+    
+    # If using OpenVINO, wrap it
+    if args.use_ov:
+        logger.info(f"Using OpenVINO model from: {args.ov_model_path} on {args.ov_device}")
+    else:
+        policy.eval()
+        logger.info("Policy instantiated and set to eval mode.")
+        policy.to(device)
+    
+    # Init RTC processor if needed (some policies like Pi0 might need it)
+    if hasattr(policy, "init_rtc_processor"):
+        logger.info("Initializing RTC processor...")
+        policy.init_rtc_processor()
+        logger.info("RTC processor initialized.")
+    
+    # Create Processors
+    # This pipeline handles Normalization -> State Tokenization -> Text Tokenization
+    logger.info("Creating pre/post processors...")
+    preprocessor, postprocessor = make_pre_post_processors(policy_cfg, dataset_stats=stats)
+    logger.info("Processors created.")
+    
+    # Determine task description
+    task_description = None
+    if ds_meta and hasattr(ds_meta, "tasks") and len(ds_meta.tasks) > 0:
+        # Just pick the first task language instruction found
+        first_task = ds_meta.tasks[0]
+        
+        # Try common keys for task description
+        # Added "index" because reset_index() on nameless index creates "index" column
+        for key in ["index", "task", "instruction", "language_instruction", "description", "prompts"]:
+            if key in first_task:
+                task_description = first_task[key]
+                if isinstance(task_description, list): # prompts is often a list
+                    task_description = task_description[0]
+                break
+
+    
+    if task_description is None:
+        # Fallback if metadata is missing text (e.g. only has task_index)
+        if "transfer" in args.task.lower():
+            task_description = "Pick up the cube with the right arm and transfer it to the left arm."
+        elif "insertion" in args.task.lower():
+            task_description = "Pick up the yellow marker with the left arm, pick up the lid with the right arm, insert the marker into the lid."
+        else:
+             task_description = args.task.replace('_', ' ').capitalize()
+        logger.info(f"Task description using fallback: '{task_description}'")
+    else:
+        logger.info(f"Using task description from metadata: '{task_description}'")
+
+    # Setup Robot
+    if args.robot_type == "real_aloha":
+        logger.info("Initializing Real Aloha Robot...")
+        real_robot = AlohaRobot()
+    elif args.robot_type == "mujoco_aloha":
+        logger.info(f"Initializing Mujoco Aloha Robot (Task: {args.task})...")
+        real_robot = MujocoAlohaRobot(args.task)
+    else:
+        raise ValueError(
+            f"Unsupported robot_type '{args.robot_type}'. "
+            "Supported types are: 'real_aloha', 'mujoco_aloha'."
+        )
+
+    robot = RobotWrapper(real_robot)
+
+    action_queue = ActionQueue(rtc_config)
+    shutdown_event = Event()
+    ready_event = Event()
+    start_execution_event = Event()
+    actor_done_event = Event()
+    
+    all_rewards = []
+
+    # Visualization setup
+    image_plot = None
+    if args.plot:
+        plt.ion()
+        fig, ax = plt.subplots()
+        # Initialize with a dummy black image usually (480, 640, 3)
+        dummy_img = np.zeros((480, 640, 3), dtype=np.uint8)
+        image_plot = ax.imshow(dummy_img)
+        plt.show(block=False)
+
+    try:
+        t_get_action = None
+        t_actor = None
+        for episode in range(args.num_episodes):
+            logger.info(f"Starting Episode {episode + 1}")
+            ready_event.clear()
+            start_execution_event.clear()
+            actor_done_event.clear()
+            
+            episode_results = []
+            log_data = {'chunks': [], 'steps': []} if args.save_traj else None
+            
+            action_queue = ActionQueue(rtc_config) 
+            
+            # Start Threads
+            t_get_action = Thread(
+                target=get_actions,
+                name="get_actions",
+                args=(
+                    policy,
+                    robot,
+                    action_queue,
+                    shutdown_event,
+                    args.fps,
+                    args.rtc_enabled,
+                    preprocessor,
+                    postprocessor,
+                    ready_event,
+                    start_execution_event,
+                    actor_done_event,
+                ),
+                kwargs=dict(
+                    min_queue_size_before_refill=args.rtc_horizon,
+                    device=device,
+                    task_description=task_description,
+                    log_data=log_data,
+                ),
+            )
+            t_actor = Thread(
+                target=actor_control,
+                name="actor_control",
+                args=(
+                    robot,
+                    action_queue,
+                    shutdown_event,
+                    args.fps,
+                    ready_event,
+                    start_execution_event,
+                    actor_done_event,
+                    episode_results,
+                    log_data,
+                    args.max_steps)
+            )
+            
+            t_get_action.start()
+            t_actor.start()
+
+            logger.info("Waiting for execution start...")
+            start_execution_event.wait()
+            logger.info("Execution started!")
+
+            start_time = time.time()
+            render_dt = 1.0 / 20.0 # Limit rendering to 20 FPS to save resources
+            last_render_time = time.time()
+            
+            while not shutdown_event.is_set():
+                if not ready_event.is_set():
+                     time.sleep(0.1)
+                     # Check if threads died while waiting
+                     if not t_actor.is_alive() or not t_get_action.is_alive():
+                         logger.error("Threads died during init!")
+                         shutdown_event.set()
+                     continue
+
+                if not t_get_action.is_alive():
+                    logger.error("Get Actions thread died!")
+                    shutdown_event.set()
+                if not t_actor.is_alive():
+                    logger.error("Actor thread died!")
+                    shutdown_event.set()
+                    
+                if args.robot_type == "mujoco_aloha" and args.plot:
+                    try:
+                        now = time.time()
+                        if now - last_render_time > render_dt:
+                            cache_images = getattr(robot.robot, "cache_images", None) or {}
+                            render_img = cache_images.get("angle", None)
+
+                            if render_img is not None:
+                                # Ensure compatible format
+                                if isinstance(render_img, torch.Tensor):
+                                    render_img = render_img.cpu().numpy()
+                                if render_img.shape[0] == 3: # C, H, W -> H, W, C
+                                    render_img = np.transpose(render_img, (1, 2, 0))
+                                
+                                # Handle potential stride issues
+                                if render_img.strides[0] < 0 or render_img.strides[1] < 0:
+                                    render_img = render_img.copy()
+
+                                image_plot.set_data(render_img)
+                                plt.pause(render_dt) 
+                            last_render_time = now
+                        else:
+                            time.sleep(0.01)
+                    except Exception as e:
+                        logger.error(f"Error in plot loop: {e}")
+                else:
+                    time.sleep(1)
+                
+            # Stop episode
+            logger.info("Episode loop ended.")
+            if shutdown_event.is_set():
+                logger.warning("Shutdown event was set!")
+            
+            shutdown_event.set()
+            # if args.plot:
+            #     plt.close('all')
+            t_get_action.join()
+            t_actor.join()
+            
+            if episode_results:
+                max_r = episode_results[0]
+                if max_r == -np.inf: max_r = 0.0
+                all_rewards.append(max_r)
+                logger.info(f"Episode {episode+1} Max Reward: {max_r}")
+
+            if args.save_traj and log_data:
+                save_trajectory_plots(log_data, args.save_traj_path, episode+1, fps=args.fps)
+
+            shutdown_event.clear() # Reset for next episode
+            
+    finally:
+        shutdown_event.set()
+
+        # If we exit early due to an exception, ensure worker threads are stopped
+        # before closing the environment to avoid EGL context ownership issues.
+        try:
+            if t_get_action is not None and t_get_action.is_alive():
+                t_get_action.join(timeout=5)
+            if t_actor is not None and t_actor.is_alive():
+                t_actor.join(timeout=5)
+        except Exception:
+            logger.exception("Failed while joining threads during shutdown; continuing cleanup.")
+
+        robot.close()
+        
+        if all_rewards:
+            all_rewards_np = np.array(all_rewards)
+            success_rate = np.mean(all_rewards_np >= 4)
+            logger.info("\n" + "="*30)
+            logger.info(f"Results Summary ({len(all_rewards)} episodes):")
+            logger.info(f"Success Rate: {success_rate * 100:.2f}%")
+            for r in range(5):
+                 count = np.sum(all_rewards_np >= r)
+                 logger.info(f"Reward >= {r}: {count}/{len(all_rewards)} ({count/len(all_rewards)*100:.1f}%)")
+            logger.info("="*30 + "\n")
+
+        logger.info("Pipeline finished.")
+
+if __name__ == "__main__":
+    main()
