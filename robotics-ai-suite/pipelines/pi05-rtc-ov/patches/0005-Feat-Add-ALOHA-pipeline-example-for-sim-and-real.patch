+++ b/examples/aloha/robot_interfaces.py
@@ -0,0 +1,234 @@
+from __future__ import annotations
+
+import logging
+from pathlib import Path
+
+import numpy as np
+import torch
+
+logger = logging.getLogger(__name__)
+
+
+class AlohaRobot:
+    def __init__(self):
+        try:
+            from aloha.robot_utils import load_yaml_file
+            from aloha.real_env import make_real_env
+            import aloha as aloha_pkg
+            from interbotix_common_modules.common_robot.robot import (
+                create_interbotix_global_node,
+                get_interbotix_global_node,
+                robot_startup,
+            )
+            from interbotix_common_modules.common_robot.exceptions import InterbotixException
+        except ImportError:
+            logger.error(
+                "Aloha robot dependencies not found. Please ensure 'aloha', 'interbotix_common_modules' are installed."
+            )
+            raise
+
+        try:
+            self.node = get_interbotix_global_node()
+        except Exception:
+            self.node = create_interbotix_global_node("aloha")
+
+        # Derive config dir from the aloha package location.
+        # Example layout:
+        #   /home/intel/interbotix_ws/src/aloha/aloha/  (python package)
+        #   /home/intel/interbotix_ws/src/aloha/config/ (configs)
+        aloha_pkg_dir = Path(getattr(aloha_pkg, "__file__", "")).resolve().parent
+        aloha_config_dir = (aloha_pkg_dir.parent / "config").resolve()
+        if not aloha_config_dir.exists():
+            raise FileNotFoundError(
+                f"Aloha config directory not found at '{aloha_config_dir}'. "
+                "If your repo layout differs, please ensure the 'config' folder sits next to the 'aloha' package."
+            )
+
+        self.robot_config = load_yaml_file("robot", "aloha_stationary", str(aloha_config_dir)).get("robot", {})
+        self.env = make_real_env(node=self.node, setup_base=False, config=self.robot_config)
+
+        try:
+            robot_startup(self.node)
+        except InterbotixException:
+            pass
+
+    def reset(self):
+        self.env.reset()
+
+    def capture_observation(self, **kwargs):
+        obs = self.env.get_observation()
+
+        # The real Aloha env exposes qpos as [right 7, left 7].
+        # The policy was trained on [left 7, right 7], so we
+        # reorder qpos into policy order before passing it on.
+        if isinstance(obs, dict) and "qpos" in obs:
+            qpos = np.asarray(obs["qpos"], dtype=float).reshape(-1)
+            if qpos.shape[0] == 14:
+                right = qpos[:7].copy()
+                left = qpos[7:14].copy()
+                # Policy expects [left (7), right (7)]
+                obs["qpos"] = np.concatenate([left, right], axis=0)
+
+        return obs
+
+    def send_action(self, action):
+        # action: [14]
+        if isinstance(action, torch.Tensor):
+            action = action.detach().cpu().numpy()
+
+        # Convert to 1D numpy array in policy order [left(7), right(7)]
+        action_np = np.asarray(action, dtype=float).reshape(-1)
+
+        # For real Aloha, the low-level env and hardware expect [right 7, left 7].
+        if action_np.shape[0] == 14:
+            left = action_np[:7].copy()
+            right = action_np[7:14].copy()
+            env_cmd_np = np.concatenate([right, left], axis=0)
+        else:
+            env_cmd_np = action_np
+
+        cmd = [float(x) for x in env_cmd_np]
+        self.env.step(cmd)
+        return 0.0
+
+    def close_env(self):
+        pass
+
+    def close(self):
+        pass
+
+
+class MujocoAlohaRobot:
+    def __init__(self, task):
+        self.task = task
+
+        # Defer env creation to reset() to handle threading contexts
+        self.env = None
+        self.time_step = None
+
+        # reward threshold used for success statistics downstream
+        self.success_reward_threshold = 4
+
+        # Rendering options: render on-demand in capture_observation (not in env.step)
+        self._camera_ids = ("top", "angle", "left_wrist", "right_wrist")
+        self._render_height = 480
+        self._render_width = 640
+
+        self.cache_images = None
+
+    def reset(self):
+        # Re-create env to ensure fresh OpenGL context for the new thread
+        if self.env is not None:
+            try:
+                self.env.close()
+            except Exception:
+                pass
+
+        # Local dm_control sim: keep the repo's environment API/observations.
+        # Note: the sim loader may still reuse gym_aloha STL meshes via
+        # `ALOHA_MESH_ASSETS_DIR` or `gym_aloha.constants.ASSETS_DIR` (see sim/sim_env.py).
+        import sys
+
+        curr_dir = Path(__file__).parent
+        if str(curr_dir) not in sys.path:
+            sys.path.append(str(curr_dir))
+
+        from sim.sim_env import BOX_POSE, make_sim_env
+        from sim.utils import sample_box_pose, sample_insertion_pose
+
+        task_name = self.task
+        if "transfer" in (task_name or "").lower():
+            task_name = "sim_transfer_cube_scripted"
+        elif "insertion" in (task_name or "").lower():
+            task_name = "sim_insertion_scripted"
+
+        logger.info("Creating local dm_control simulation environment: %s", task_name)
+        self.env = make_sim_env(
+            task_name,
+            render_images=False,
+        )
+
+        if "sim_transfer_cube" in task_name:
+            BOX_POSE[0] = sample_box_pose()
+        elif "sim_insertion" in task_name:
+            BOX_POSE[0] = np.concatenate(sample_insertion_pose())
+
+        self.time_step = self.env.reset()
+
+    def capture_observation(self, render_image: bool = False):
+        obs = self.time_step.observation
+        mapped_obs = {"images": {}}
+
+        if render_image:
+            physics = self.env.physics
+            rendered = {}
+            for cam_id in self._camera_ids:
+                rendered[cam_id] = physics.render(
+                    height=self._render_height,
+                    width=self._render_width,
+                    camera_id=cam_id,
+                )
+
+            images = {}
+            if "top" in rendered:
+                images["camera_high"] = rendered["top"]
+            if "angle" in rendered:
+                images["camera_low"] = rendered["angle"]
+            if "left_wrist" in rendered:
+                images["camera_wrist_left"] = rendered["left_wrist"]
+            if "right_wrist" in rendered:
+                images["camera_wrist_right"] = rendered["right_wrist"]
+
+            mapped_obs["images"] = images
+            self.cache_images = rendered
+
+        if "qpos" in obs:
+            mapped_obs["qpos"] = obs["qpos"]
+
+        return mapped_obs
+
+    def send_action(self, action):
+        if isinstance(action, torch.Tensor):
+            action = action.cpu().numpy()
+        self.time_step = self.env.step(action)
+        return self.time_step.reward
+
+    def close_env(self):
+        if self.env is not None:
+            try:
+                self.env.close()
+            except Exception:
+                pass
+            self.env = None
+
+    def close(self):
+        self.close_env()
+
+
+class RobotWrapper:
+    def __init__(self, robot):
+        from threading import Lock
+
+        self.robot = robot
+        self.lock = Lock()
+
+    def reset(self):
+        with self.lock:
+            self.robot.reset()
+
+    def get_observation(self, render_image: bool = False):
+        with self.lock:
+            return self.robot.capture_observation(render_image=render_image)
+
+    def send_action(self, action):
+        with self.lock:
+            return self.robot.send_action(action)
+
+    def close_env(self):
+        with self.lock:
+            if hasattr(self.robot, "close_env"):
+                self.robot.close_env()
+
+    def close(self):
+        with self.lock:
+            self.robot.close()
