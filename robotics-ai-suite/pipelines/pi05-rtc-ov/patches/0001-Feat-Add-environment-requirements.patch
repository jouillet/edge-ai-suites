From 932a9a16bb2640a3590adb58f438cb418b45683b Mon Sep 17 00:00:00 2001
From: "Liu, Baihe" <baihe.liu@intel.com>
Date: Mon, 12 Jan 2026 11:10:06 +0800
Subject: [PATCH 1/6] [Feat] Add environment requirements

---
 pyproject.toml | 70 +++++++++++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 69 insertions(+), 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
index fa4b22b..16eca68 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -29,7 +29,7 @@ version = "0.4.3"
 description = "🤗 LeRobot: State-of-the-art Machine Learning for Real-World Robotics in Pytorch"
 dynamic = ["readme"]
 license = { text = "Apache-2.0" }
-requires-python = ">=3.10"
+requires-python = ">=3.10,<3.11"
 authors = [
     { name = "Rémi Cadène", email = "re.cadene@gmail.com" },
     { name = "Simon Alibert", email = "alibert.sim@gmail.com" },
@@ -128,6 +128,14 @@ wallx = [
     "qwen_vl_utils==0.0.11"
 ]
 pi = ["transformers @ git+https://github.com/huggingface/transformers.git@fix/lerobot_openpi", "scipy>=1.10.1,<1.15"]
+pi-ov = [
+    "transformers @ git+https://github.com/huggingface/transformers.git@fix/lerobot_openpi",
+    "scipy>=1.10.1,<1.15",
+    "torch>=2.2.1,<2.8.0",
+    "torchvision>=0.21.0,<0.23.0",
+    "torchcodec>=0.2.1,<0.6.0; sys_platform != 'win32' and (sys_platform != 'linux' or (platform_machine != 'aarch64' and platform_machine != 'arm64' and platform_machine != 'armv7l')) and (sys_platform != 'darwin' or platform_machine != 'x86_64')",
+    "openvino==2026.0",
+]
 smolvla = ["lerobot[transformers-dep]", "num2words>=0.5.14,<0.6.0", "accelerate>=1.7.0,<2.0.0", "safetensors>=0.4.3,<1.0.0"]
 groot = [
     "lerobot[transformers-dep]",
@@ -396,6 +404,10 @@ conflicts = [
         { extra = "wallx" },
         { extra = "pi" },
     ],
+    [
+        { extra = "wallx" },
+        { extra = "pi-ov" },
+    ],
     [
         { extra = "wallx" },
         { extra = "smolvla" },
@@ -433,36 +445,92 @@ conflicts = [
         { extra = "pi" },
         { extra = "transformers-dep" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "transformers-dep" },
+    ],
     [
         { extra = "pi" },
         { extra = "smolvla" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "smolvla" },
+    ],
     [
         { extra = "pi" },
         { extra = "groot" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "groot" },
+    ],
     [
         { extra = "pi" },
         { extra = "xvla" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "xvla" },
+    ],
     [
         { extra = "pi" },
         { extra = "sarm" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "sarm" },
+    ],
     [
         { extra = "pi" },
         { extra = "hilserl" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "hilserl" },
+    ],
     [
         { extra = "pi" },
         { extra = "libero" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "libero" },
+    ],
     [
         { extra = "pi" },
         { extra = "peft" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "peft" },
+    ],
     [
         { extra = "pi" },
         { extra = "all" },
     ],
+    [
+        { extra = "pi-ov" },
+        { extra = "all" },
+    ],
+    [
+        { extra = "pi" },
+        { extra = "pi-ov" },
+    ],
+]
+
+[[tool.uv.index]]
+name = "pytorch-cpu"
+url = "https://download.pytorch.org/whl/cpu"
+explicit = true
+
+[tool.uv.sources]
+torch = [
+    { index = "pytorch-cpu", extra = "pi-ov" },
+]
+torchvision = [
+    { index = "pytorch-cpu", extra = "pi-ov" },
+]
+torchcodec = [
+    { index = "pytorch-cpu", extra = "pi-ov" },
 ]
