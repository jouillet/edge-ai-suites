--- /dev/null
+++ b/examples/pi05_with_openvino/scripts/benchmark_pi05_ov_rtc.py
@@ -0,0 +1,205 @@
+import numpy as np
+import torch
+import time
+import argparse
+from lerobot.policies.pi05.configuration_pi05 import PI05Config, OVConfig
+from lerobot.policies.pi05.modeling_pi05 import PI05Policy
+from lerobot.policies.pi05.processor_pi05 import make_pi05_pre_post_processors
+from lerobot.configs.types import RTCAttentionSchedule
+from lerobot.policies.rtc.configuration_rtc import RTCConfig
+
+from lerobot.configs.types import FeatureType, PolicyFeature
+
+"""
+Benchmark script for PI05 policy using OpenVINO with RTC.
+
+Usage: 
+- Install dependencies with: uv sync --extra pi-ov
+- Run test with: uv run --extra pi-ov benchmark_pi05_ov_rtc.py --model_dir <path_to_openvino_model> --device <device_name> [-n <number_of_runs>] [--disable_rtc] [--run_torch] [--torch_dir <path_to_torch_model>]
+
+"""
+torch.manual_seed(42)
+
+parser = argparse.ArgumentParser()
+parser.add_argument("--model_dir", type=str, default="./pi05_rtc_lerobot_ov_ir_4c_FP16", help="Path to OpenVINO model directory")
+parser.add_argument("--camera_num", "-c", type=int, default=4, help="Number of cameras used in the model")
+parser.add_argument("--device", type=str, default="CPU", help="Device to run inference on")
+parser.add_argument("--run_torch", action="store_true", help="Whether to run the original PyTorch model for output comparison.")
+parser.add_argument("--torch_dir",  type=str, default="lerobot/pi05_base", help="Path to PyTorch model directory for comparison if --run_torch is set")
+parser.add_argument("--num_runs" , "-n", type=int, default=10, help="Number of runs for averaging inference time")
+parser.add_argument("--num_warmup", type=int, default=3, help="Number of warmup runs, 0 to disable")
+parser.add_argument("--disable_rtc", action="store_true", default=False, help="Disable RTC functionality")
+args = parser.parse_args()
+
+if args.num_runs <= 0:
+    parser.error("--num_runs must be at least 1")
+
+image_keys = [
+    "observation.images.cam_high",
+    "observation.images.cam_low",
+    "observation.images.cam_left_wrist",
+    "observation.images.cam_right_wrist",
+][:args.camera_num]
+
+config = PI05Config(
+    input_features={
+        **{key: PolicyFeature(type=FeatureType.VISUAL, shape=(3, 224, 224)) for key in image_keys},
+        "observation.state": PolicyFeature(type=FeatureType.STATE, shape=(14,)),
+    },
+    output_features={
+        "action": PolicyFeature(type=FeatureType.ACTION, shape=(14,)),
+    },
+)
+
+dummy_input = {
+        "observation.state": torch.ones(14),
+        **{key: torch.randint(256, size=(3, 224, 224), dtype=torch.uint8) for key in image_keys},
+        "task": "do something",
+    }   # batch dim will be added in preprocessor for only torch.Tensor but not np.ndarray
+
+dataset_stats = {
+    "observation.state": {
+        "mean": torch.zeros(14),
+        "std": torch.ones(14),
+        "min": torch.zeros(14),
+        "max": torch.ones(14),
+        "q01": torch.zeros(14),
+        "q99": torch.ones(14),
+    },
+    "action": {
+        "mean": torch.zeros(14),
+        "std": torch.ones(14),
+        "min": torch.zeros(14),
+        "max": torch.ones(14),
+        "q01": torch.zeros(14),
+        "q99": torch.ones(14),
+    },
+    "observation.images.cam_high": {
+        "mean": torch.zeros(3, 224, 224),
+        "std": torch.ones(3, 224, 224),
+        "q01": torch.zeros(3, 224, 224),
+        "q99": torch.ones(3, 224, 224),
+    },
+    "observation.images.cam_low": {
+        "mean": torch.zeros(3, 224, 224),
+        "std": torch.ones(3, 224, 224),
+        "q01": torch.zeros(3, 224, 224),
+        "q99": torch.ones(3, 224, 224),
+    },
+    "observation.images.cam_left_wrist": {
+        "mean": torch.zeros(3, 224, 224),
+        "std": torch.ones(3, 224, 224),
+        "q01": torch.zeros(3, 224, 224),
+        "q99": torch.ones(3, 224, 224),
+    },
+    "observation.images.cam_right_wrist": {
+        "mean": torch.zeros(3, 224, 224),
+        "std": torch.ones(3, 224, 224),
+        "q01": torch.zeros(3, 224, 224),
+        "q99": torch.ones(3, 224, 224),
+    },
+}
+
+preprocessor, postprocessor = make_pi05_pre_post_processors(config, dataset_stats=dataset_stats)
+
+if args.disable_rtc:
+    print("Disable RTC...")
+    rtc_args = {}
+else:
+    print("Enable RTC...")
+    rtc_args = {
+        "prev_chunk_left_over": torch.randn(1, 25, 32, dtype=torch.float32),
+        "inference_delay": 8,
+        "execution_horizon": 25,
+    }
+
+ov_config = OVConfig(model_dir=args.model_dir, device=args.device)
+policy = PI05Policy(config=config, ov_config=ov_config)
+
+noise = policy.model.sample_noise((1, config.chunk_size, 32), torch.device("cpu"))
+
+if args.run_torch:
+    print("Running PyTorch model...")
+    torch_policy = PI05Policy.from_pretrained(args.torch_dir, config=config)
+
+    if not args.disable_rtc:
+        torch_policy.config.rtc_config = RTCConfig(
+            enabled=True,
+            execution_horizon=10,
+            max_guidance_weight=5.0,
+            prefix_attention_schedule=RTCAttentionSchedule.EXP,
+            debug=False,
+        )
+
+    torch_policy.init_rtc_processor()
+    device = torch.device("cpu")
+    torch_policy.to(device)
+    torch_policy.eval()
+
+    batch = preprocessor(dummy_input)
+    torch_output = torch_policy.predict_action_chunk(batch, noise=noise, **rtc_args)
+    torch_action = postprocessor(torch_output)
+    del torch_policy
+        
+# Warmup
+if args.num_warmup > 0:
+    print(f"Warming up for {args.num_warmup} runs...")
+    for _ in range(args.num_warmup):
+        batch = preprocessor(dummy_input)
+        output = policy.predict_action_chunk(batch, noise=noise, **rtc_args)
+        action = postprocessor(output)
+
+print("Measuring average time...")
+num_runs = args.num_runs
+preprocess_time = []
+inference_time = []
+postprocess_time = []
+
+for _ in range(num_runs):
+    start_time = time.time()
+    batch = preprocessor(dummy_input)
+    preprocess_time.append(time.time() - start_time)
+
+    start_time = time.time()
+    output = policy.predict_action_chunk(batch, noise=noise, **rtc_args)
+    inference_time.append(time.time() - start_time) 
+    print(f"Inference time: {inference_time[-1]:.4f}s")
+
+    start_time = time.time()
+    action = postprocessor(output)
+    postprocess_time.append(time.time() - start_time)
+
+print(f"Average Preprocess time: {np.mean(preprocess_time):.4f}s")
+print(f"Average Inference time: {np.mean(inference_time):.4f}s")
+print(f"Average Postprocess time: {np.mean(postprocess_time):.4f}s")
+print(f"Total Average loop time: {np.mean(preprocess_time) + np.mean(inference_time) + np.mean(postprocess_time):.4f}s")
+
+print("Predicted action:", action.shape)
+
+# compare results between torch and ov
+if args.run_torch:
+    arr1 = torch_action.numpy()
+    arr2 = action.numpy()
+
+    diff = np.abs(arr1 - arr2)
+    max_abs = np.max(diff)
+    p99_abs = np.percentile(diff, 99)
+    # Avoid division by zero
+    max_rel = np.max(diff / (np.maximum(np.abs(arr1), 1e-8)))
+
+    # Metrics
+    mse = np.mean(np.square(arr1 - arr2))
+    mae = np.mean(diff)
+
+    # Cosine Similarity
+    v1, v2 = arr1.flatten(), arr2.flatten()
+    norm1, norm2 = np.linalg.norm(v1), np.linalg.norm(v2)
+    if norm1 > 1e-8 and norm2 > 1e-8:
+        cos_sim = np.dot(v1, v2) / (norm1 * norm2)
+    else:
+        cos_sim = 0.0
+
+    print(f"Output Comparison between PyTorch and OpenVINO implementations")
+    print(f"  Max Abs: {max_abs:.6g}, P99 Abs: {p99_abs:.6g}, Max Rel: {max_rel:.6g}")
+    print(f"  MSE: {mse:.6g}, MAE: {mae:.6g}, Cos Sim: {cos_sim:.6g}")
+
