+#!/usr/bin/env python
+
+"""Test script to verify OpenVINO support in PI0.5 (pi05) policy."""
+"""Usage: uv run --with pytest --extra pi-ov pytest tests/policies/pi0_pi05/test_pi05_ov_rtc.py"""
+
+import os
+import sys
+from unittest.mock import MagicMock, patch
+
+import pytest
+import torch
+
+from lerobot.configs.types import FeatureType, PolicyFeature
+from lerobot.policies.pi05.configuration_pi05 import OVConfig, PI05Config
+from lerobot.policies.pi05 import PI05Policy
+from lerobot.utils.constants import ACTION, OBS_LANGUAGE_TOKENS, OBS_LANGUAGE_ATTENTION_MASK
+
+# Skip this entire module in CI
+pytestmark = pytest.mark.skipif(
+    os.environ.get("CI") == "true" or os.environ.get("GITHUB_ACTIONS") == "true",
+    reason="This test requires local OpenPI installation and is not meant for CI",
+)
+
+@pytest.fixture
+def mock_openvino():
+    with patch.dict(sys.modules, {"openvino": MagicMock()}):
+        yield sys.modules["openvino"]
+
+@pytest.fixture
+def pi05_config():
+    config = PI05Config(max_action_dim=7, max_state_dim=14, dtype="float32", device="cpu")
+    config.input_features = {
+        "observation.state": PolicyFeature(
+            type=FeatureType.STATE,
+            shape=(14,),
+        ),
+        "observation.images.base_0_rgb": PolicyFeature(
+            type=FeatureType.VISUAL,
+            shape=(3, 224, 224),
+        ),
+    }
+    config.output_features = {
+        "action": PolicyFeature(
+            type=FeatureType.ACTION,
+            shape=(7,),
+        ),
+    }
+    return config
+
+def setup_mock_ov(mock_openvino, input_names):
+    mock_core = MagicMock()
+    mock_openvino.Core.return_value = mock_core
+    mock_model = MagicMock()
+    mock_compiled_model = MagicMock()
+    mock_core.read_model.return_value = mock_model
+    mock_core.compile_model.return_value = mock_compiled_model
+    
+    # Mock inputs
+    inputs = []
+    for name in input_names:
+        input_node = MagicMock()
+        input_node.get_names.return_value = {name}
+        inputs.append(input_node)
+    mock_compiled_model.inputs = inputs
+    
+    # Mock infer request
+    mock_infer_request = MagicMock()
+    mock_compiled_model.create_infer_request.return_value = mock_infer_request
+    
+    return mock_compiled_model, mock_infer_request
+
+def test_ov_config_initialization():
+    config = OVConfig(model_dir="/tmp/model", device="CPU")
+    assert config.model_dir == "/tmp/model"
+    assert config.device == "CPU"
+
