+        has_rtc_inputs = False
+        for input_node in self.ov_model.inputs:
+            if "prev_chunk_left_over" in input_node.get_names():
+                has_rtc_inputs = True
+                break
+
+        if has_rtc_inputs:
+            inference_delay = kwargs.get("inference_delay")
+            prev_chunk_left_over = kwargs.get("prev_chunk_left_over")
+            execution_horizon = kwargs.get("execution_horizon")
+
+            # Input arguments for RTC should be type of Tensor
+            # If RTC is disabled, set args to zero tensors
+            if prev_chunk_left_over is None:
+                prev_chunk_left_over = torch.zeros(
+                    (tokens.shape[0], self.config.chunk_size, self.config.output_features[ACTION].shape[0]), dtype=torch.float32
+                )
+                inference_delay_tensor = torch.tensor(0.0, dtype=torch.float32)
+                execution_horizon_tensor = torch.tensor(0.0, dtype=torch.float32)
+            else:
+                inference_delay_tensor = (torch.tensor(inference_delay, dtype=torch.float32)
+                    if inference_delay is not None else torch.tensor(0.0, dtype=torch.float32))
+                execution_horizon_tensor = (torch.tensor(execution_horizon, dtype=torch.float32)
+                    if execution_horizon is not None else torch.tensor(self.rtc_config.execution_horizon, dtype=torch.float32))
+
+        inputs = {
+            "images": images.cpu(),
+            "img_masks": img_masks.cpu(),
+            "lang_tokens": tokens.cpu(),
+            "lang_masks": masks.cpu(),
+            "noise": noise.cpu(),
+        }
+
+        if has_rtc_inputs:
+            inputs.update({
+                "prev_chunk_left_over": prev_chunk_left_over.cpu(),
+                "inference_delay": inference_delay_tensor.cpu(),
+                "execution_horizon": execution_horizon_tensor.cpu(),
+            })
+
+        outputs = self.infer_request.infer(inputs)
+
+        return torch.tensor(outputs["actions_out"]).to(device=tokens.device)
