@@ -0,0 +1,370 @@
+import torch
+from lerobot.policies.pi05.modeling_pi05 import PI05Policy
+from lerobot.policies.pi05.configuration_pi05 import PI05Config
+from lerobot.configs.policies import PreTrainedConfig
+from lerobot.datasets.lerobot_dataset import LeRobotDataset
+from lerobot.policies.factory import make_pre_post_processors
+from lerobot.utils.constants import OBS_LANGUAGE_TOKENS, OBS_LANGUAGE_ATTENTION_MASK
+
+import os
+import json
+import tempfile
+import numpy as np
+import openvino as ov
+import argparse
+from pathlib import Path
+
+
+parser = argparse.ArgumentParser(description="Convert PyTorch Pi05Policy to ONNX and OpenVINO IR")
+parser.add_argument("--camera_num", "-c", type=int, default=4, help="Batch size for image input/number of cameras")
+parser.add_argument("--torch_dir", type=str, default="lerobot/pi05_base", help="Path to the pretrained PyTorch model")
+parser.add_argument("--dataset_path", type=str, default=None, help="Path to local LeRobot dataset for real inputs")
+parser.add_argument("--onnx_output_dir", type=str, default="pi05_onnx", help="Path to save the ONNX model")
+parser.add_argument("--ov_output_dir", type=str, default="pi05_lerobot_ov_ir", help="Path to save the OpenVINO IR model")
+parser.add_argument("--compress_int8", action="store_true", help="Whether to compress models to INT8")
+parser.add_argument("--save_fp32", action="store_true", help="Whether to save OpenVINO model in FP32 format (FP16 by default)")
+parser.add_argument("--override", action="store_true", help="Whether to override existing files")
+
+args = parser.parse_args()
+
+# -----------------------------
+# Load PyTorch policy
+# -----------------------------
+print(f"LOADING MODEL from {args.torch_dir}")
+
+# Handle extra keys in config that might cause issues (similar to eval_aloha.py)
+config_path = Path(args.torch_dir) / "config.json"
+policy_cfg = None
+
+if config_path.exists():
+    with open(config_path, "r") as f:
+        cfg_dict = json.load(f)
+    
+    # "type" is a property in PreTrainedConfig, not a field, so draccus fails if it's in the json
+    # when loading the subclass directly. However, PreTrainedConfig.from_pretrained REQUIRES "type".
+    # so we must leave it if we use PreTrainedConfig.from_pretrained.
+    invalid_keys = ["use_peft", "freeze_vision_encoder", "train_expert_only"]
+    dirty = False
+    for k in invalid_keys:
+        if k in cfg_dict:
+            del cfg_dict[k]
+            dirty = True
+            
+    if dirty:
+        print(f"Sanitizing config: removed deprecated keys {invalid_keys}")
+        with tempfile.TemporaryDirectory() as temp_dir:
+            temp_config_path = Path(temp_dir) / "config.json"
+            with open(temp_config_path, "w") as f:
+                json.dump(cfg_dict, f)
+            policy_cfg = PreTrainedConfig.from_pretrained(str(Path(temp_dir)))
+    else:
+        policy_cfg = PreTrainedConfig.from_pretrained(args.torch_dir)
+else:
+    policy_cfg = PreTrainedConfig.from_pretrained(args.torch_dir)
+
+# Disable compilation for tracing/export
+if hasattr(policy_cfg, "compile_model"):
+    print("Disabling model compilation for export...")
+    policy_cfg.compile_model = False
+
+policy = PI05Policy.from_pretrained(args.torch_dir, config=policy_cfg)
+device = torch.device("cpu")  # force CPU to avoid mixed precision issues
+policy.to(device)
+policy.eval()
+print("Done loading policy.")
+
+# -----------------------------
+# Define inference wrapper
+# -----------------------------
+class Pi05InferenceWrapper(torch.nn.Module):
+    def __init__(self, pi05_policy):
+        super().__init__()
+        self.model = pi05_policy.model
+
+    def forward(self, images, img_masks, lang_tokens, lang_masks, noise):
+        # Ensure all internal constants are float32
+        images = images.float()
+        
+        # Convert masks to int because ONNX doesn't support CumSum on booleans
+        img_masks = img_masks.long()
+        lang_masks = lang_masks.long()
+        
+        # out = self.model(images, img_masks, lang_tokens, lang_masks, state, actions)
+        out = self.model.sample_actions(images, img_masks, lang_tokens, lang_masks, noise)
+       
+        if torch.is_complex(out):
+            out = out.real
+    
+        return out
+
+
+inference_model = Pi05InferenceWrapper(policy)
+inference_model.to(device)
+inference_model.eval()
+
+# -----------------------------
+# Cast parameters and buffers to float32
+# -----------------------------
+for name, buf in inference_model.named_buffers():
+    if buf.dtype == torch.bfloat16:
+        # print("Casting buffer:", name)
+        buf.data = buf.data.float()
+    elif buf.dtype in [torch.int32, torch.int64]:
+        # leave these alone (needed for Gather, indexing, etc.)
+        pass
+
+for name, param in inference_model.named_parameters():
+    if param.dtype == torch.bfloat16:
+        # print("Casting param:", name)
+        param.data = param.data.float()
+
+# -----------------------------
+# Create Inputs (Real or Dummy)
+# -----------------------------
+vocab_size = 30522
+T = policy.config.n_obs_steps
+B = args.camera_num
+C, H, W = 3, 224, 224
+B_lang = 1
+T_lang = policy.config.tokenizer_max_length
+
+if hasattr(policy.config, "image_resolution"):
+     H, W = policy.config.image_resolution
+
+images = None
+img_masks = None
+lang_tokens = None
+lang_masks = None
+noise = None
+
+if args.dataset_path:
+    print(f"Using REAL DATASET from {args.dataset_path}")
+    ds = LeRobotDataset(repo_id="local", root=args.dataset_path)
+    # stats are in ds.meta.stats
+    stats = ds.meta.stats
+    
+    # Create preprocessor
+    # make_pre_post_processors uses policy.config to determine keys and normalization
+    preprocessor, _ = make_pre_post_processors(policy.config, dataset_stats=stats)
+    
+    # Get sample (first item)
+    item = ds[0]
+    
+    # Preprocess
+    # We need to add batch dim to all tensors in item, making B=1
+    observation = {}
+    for k, v in item.items():
+         if isinstance(v, torch.Tensor):
+             observation[k] = v.unsqueeze(0).to(device)
+         else:
+             observation[k] = [v] # keep list for strings/text
+             
+    batch = preprocessor(observation)
+    
+    # Move batch keys to device just in case
+    for k in batch:
+        if isinstance(batch[k], torch.Tensor):
+             batch[k] = batch[k].to(device)
+
+    # Get tensors ready for model
+    # _preprocess_images returns lists of tensors (one per camera)
+    images_list, img_masks_list = policy._preprocess_images(batch)
+    
+    # Stack images list -> [N_cams, B, C, H, W]
+    # This matches the structure expected by sample_actions (iterating over cameras)
+    # assuming B=1 from our unsqueeze logic.
+    images = torch.stack(images_list)
+    img_masks = torch.stack(img_masks_list)
+    
+    lang_tokens = batch[OBS_LANGUAGE_TOKENS]
+    lang_masks = batch[OBS_LANGUAGE_ATTENTION_MASK]
+    
+    # Noise still needs to be random
+    noise = torch.randn(1, policy.model.config.chunk_size, policy.model.config.max_action_dim, device=device).float()
+    
+    print(f"Real inputs prepared.")
+    print(f"  Images shape: {images.shape}")
+    print(f"  Lang tokens shape: {lang_tokens.shape}")
+
+else:
+    print("Using DUMMY inputs")
+    # Original dummy logic
+    images = torch.randn(B, T, C, H, W, device=device).float()
+    img_masks = torch.ones(B, T, dtype=torch.bool, device=device)
+    lang_tokens = torch.randint(0, vocab_size, (B_lang, T_lang), device=device).long()
+    lang_masks = torch.ones(B_lang, T_lang, dtype=torch.bool, device=device)
+    noise = torch.randn(1, policy.model.config.chunk_size, policy.model.config.max_action_dim, device=device).float()
+
+# -----------------------------
+# Export to ONNX
+# -----------------------------
+onnx_dir = args.onnx_output_dir + f"_{args.camera_num}c"
+onnx_path = os.path.join(onnx_dir, "pi05.onnx")
+
+if not os.path.exists(onnx_path) or args.override:
+    os.makedirs(onnx_dir, exist_ok=True)
+    print(f"Exporting ONNX model to {onnx_path}...")
+    torch.onnx.export(
+        inference_model,
+        (images, img_masks, lang_tokens, lang_masks, noise),
+        onnx_path,
+        input_names=["images", "img_masks", "lang_tokens", "lang_masks", "noise"],
+        output_names=["actions_out"],
+        opset_version=14,
+        do_constant_folding=False,
+    )
+    print(f"ONNX model exported to {onnx_path}")
+else:
+    print(f"ONNX model {onnx_path} already exists. Skipping export.")
+
+# -----------------------------
+# OpenVINO Conversion
+# -----------------------------
+suffix = "_FP32" if args.save_fp32 else "_FP16"
+suffix = f"_{args.camera_num}c" + suffix
+ov_model_path = os.path.join(args.ov_output_dir + suffix, "model.xml")
+
+if not os.path.exists(ov_model_path) or args.override:
+    os.makedirs(args.ov_output_dir + suffix, exist_ok=True)
+    print(f"Converting to OpenVINO IR: {ov_model_path}")
+    ov_model = ov.convert_model(onnx_path)
+
+    ov.save_model(ov_model, 
+                output_model=ov_model_path, 
+                compress_to_fp16=not args.save_fp32)
+    print(f"OpenVINO model saved to {ov_model_path}")
+else:
+    print(f"OpenVINO model {ov_model_path} already exists. Skipping conversion.")
+
+model_int8_dir = args.ov_output_dir + f"_{args.camera_num}c_INT8"
+if args.compress_int8 and (not os.path.exists(os.path.join(model_int8_dir, "model.xml")) or args.override):
+    try:
+        from nncf import compress_weights, CompressWeightsMode
+        print("Applying INT8 compression...")
+        
+        os.makedirs(model_int8_dir, exist_ok=True)
+        core = ov.Core()
+        ov_model = core.read_model(ov_model_path)
+        int8_ov_model = compress_weights(
+            ov_model, 
+            mode=CompressWeightsMode.INT8_ASYM,
+        )
+
+        ov.save_model(int8_ov_model, output_model=os.path.join(model_int8_dir, "model.xml"))
+
+    except ImportError:
+        print("NNCF not found. Skipping INT8 compression.")
+    except Exception as e:
+        print(f"INT8 compression failed: {e}")
+
+# -----------------------------
+# Inference & Comparison
+# -----------------------------
+def compare_tensors(name: str, tensor_1, tensor_2, atol=1e-4, rtol=1e-3):
+    def to_numpy(t):
+        if isinstance(t, torch.Tensor):
+            return t.detach().cpu().float().numpy()
+        if hasattr(t, "numpy"):
+            return t.numpy()
+        return np.asarray(t)
+
+    arr1 = to_numpy(tensor_1)
+    arr2 = to_numpy(tensor_2)
+
+    if arr1.shape != arr2.shape:
+        print(f"Shape mismatch comparing {name}: {arr1.shape} vs {arr2.shape}")
+        return False
+
+    diff = np.abs(arr1 - arr2)
+    max_abs = np.max(diff)
+    p99_abs = np.percentile(diff, 99)
+    # Avoid division by zero
+    max_rel = np.max(diff / (np.maximum(np.abs(arr1), 1e-8)))
+
+    # Metrics
+    mse = np.mean(np.square(arr1 - arr2))
+    mae = np.mean(diff)
+
+    # Cosine Similarity
+    v1, v2 = arr1.flatten(), arr2.flatten()
+    norm1, norm2 = np.linalg.norm(v1), np.linalg.norm(v2)
+    if norm1 > 1e-8 and norm2 > 1e-8:
+        cos_sim = np.dot(v1, v2) / (norm1 * norm2)
+    else:
+        cos_sim = 0.0
+
+    ok = np.allclose(arr1, arr2, rtol=rtol, atol=atol)
+
+    print(f"Compare {name}:")
+    print(f"  np.allclose: {ok}")
+    print(f"  Max Abs: {max_abs:.6g}, P99 Abs: {p99_abs:.6g}, Max Rel: {max_rel:.6g}")
+    print(f"  MSE: {mse:.6g}, MAE: {mae:.6g}, Cos Sim: {cos_sim:.6g}")
+    return ok
+
+def run_ov_inference(xml_path: str, inputs: dict) -> dict:
+    """Load OpenVINO IR and run inference with numpy inputs. Returns a dict of outputs as numpy arrays."""
+    from openvino.properties import hint as hints
+    core = ov.Core()
+    core.set_property(
+        "CPU",
+        {hints.execution_mode: hints.ExecutionMode.ACCURACY},
+    )
+    model = core.read_model(xml_path)
+    compiled = core.compile_model(model, device_name="CPU")
+
+    ov_inputs = {}
+    for name, arr in inputs.items():
+        # OpenVINO expects numpy arrays
+        if isinstance(arr, torch.Tensor):
+            ov_inputs[name] = arr.cpu().numpy()
+        else:
+            ov_inputs[name] = arr
+
+    results = compiled(ov_inputs)
+    # compiled(inputs=...) returns a dict of output_name -> numpy array
+    return results
+
+def run_onnx_inference(onnx_path: str, inputs: dict) -> dict:
+    """Run ONNX Runtime inference and return output dict."""
+    import onnxruntime as ort
+    # Prepare inputs: convert torch tensors to numpy
+    ort_inputs = {}
+    for name, arr in inputs.items():
+        ort_inputs[name] = arr.detach().cpu().numpy() if isinstance(arr, torch.Tensor) else np.asarray(arr)
+
+    sess = ort.InferenceSession(onnx_path, providers=["CPUExecutionProvider"])
+    out_names = [o.name for o in sess.get_outputs()]
+    out = sess.run(out_names, ort_inputs)
+    return dict(zip(out_names, out))
+
+print("Running PyTorch Inference for Baseline...")
+with torch.no_grad():
+    torch_out = inference_model(images, img_masks, lang_tokens, lang_masks, noise)
+
+print("Running ONNX Inference...")
+inputs = {
+    "images": images.cpu(),
+    "img_masks": img_masks.cpu(),
+    "lang_tokens": lang_tokens.cpu(),
+    "lang_masks": lang_masks.cpu(),
+    "noise": noise.cpu(),
+}
+onnx_results = run_onnx_inference(onnx_path, inputs)
+onnx_out = onnx_results["actions_out"]
+
+print("Running OpenVINO Inference...")
+ov_results = run_ov_inference(ov_model_path, inputs)
+ov_out = ov_results["actions_out"]
+
+print("Comparing Results...")
+print("=====================================================")
+compare_tensors("PyTorch(Wrapper) vs ONNX", torch_out, onnx_out)
+compare_tensors("ONNX vs OpenVINO", onnx_out, ov_out)
+compare_tensors("PyTorch(Wrapper) vs OpenVINO", torch_out, ov_out)
+if args.compress_int8:
+    try:
+        int8_result = run_ov_inference(os.path.join(args.ov_output_dir + f"_{args.camera_num}c_INT8", "model.xml"), inputs)
+        compare_tensors("PyTorch(Wrapper) vs OpenVINO(INT8)", torch_out, int8_result["actions_out"])
+    except Exception as e:
+        print(f"INT8 inference failed: {e}")
+
