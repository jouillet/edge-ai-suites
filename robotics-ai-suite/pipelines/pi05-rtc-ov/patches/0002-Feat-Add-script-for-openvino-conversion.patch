+        # out = self.model(images, img_masks, lang_tokens, lang_masks, state, actions)
+        out = self.sample_actions(images, img_masks, lang_tokens, lang_masks, noise, prev_chunk_left_over, inference_delay, execution_horizon)
+
+       
+        if torch.is_complex(out):
+            out = out.real
+        
+        torch.save(out, "validation/lerobot_pytorch_pi05_output.pt")
+        return out
+    
+    @torch.no_grad()  # see openpi `sample_actions` (slightly adapted)
+    def sample_actions(
+        self,
+        images,
+        img_masks,
+        tokens,
+        masks,
+        noise,
+        prev_chunk_left_over,
+        inference_delay,
+        execution_horizon, 
+        num_steps=None,
+    ) -> Tensor:
+        """Do a full inference forward and compute the action."""
+        if num_steps is None:
+            num_steps = self.model.config.num_inference_steps
+
+        bsize = tokens.shape[0]
+        device = tokens.device
+
+        prefix_embs, prefix_pad_masks, prefix_att_masks = self.model.embed_prefix(images, img_masks, tokens, masks)
+        prefix_att_2d_masks = make_att_2d_masks(prefix_pad_masks, prefix_att_masks.long())
+        prefix_position_ids = torch.cumsum(prefix_pad_masks, dim=1) - 1
+
+        prefix_att_2d_masks_4d = self.model._prepare_attention_masks_4d(prefix_att_2d_masks.bool())
+        self.model.paligemma_with_expert.paligemma.language_model.config._attn_implementation = "eager"  # noqa: SLF001
+
+        _, past_key_values = self.model.paligemma_with_expert.forward(
+            attention_mask=prefix_att_2d_masks_4d,
+            position_ids=prefix_position_ids,
+            past_key_values=None,
+            inputs_embeds=[prefix_embs, None],
+            use_cache=True,
+        )
+
+        dt = -1.0 / num_steps
+
+        x_t = noise
+        for step in range(num_steps):
+            time = 1.0 + step * dt
+            time_tensor = torch.tensor(time, dtype=torch.float32, device=device).expand(bsize)
+
+            def denoise_step_partial_call(input_x_t, current_timestep=time_tensor):
+                return self.model.denoise_step(
+                    prefix_pad_masks=prefix_pad_masks,
+                    past_key_values=past_key_values,
+                    x_t=input_x_t,
+                    timestep=current_timestep,
+                )
+            v_t = self.rtc_processor.denoise_step(
+                    x_t=x_t,
+                    prev_chunk_left_over=prev_chunk_left_over,
+                    inference_delay=inference_delay,
+                    time=time,
+                    original_denoise_step_partial=denoise_step_partial_call,
+                    execution_horizon=execution_horizon,
+                )
+
+            x_t = x_t + dt * v_t
+        return x_t
+    
+    def rtc_denoise_step(
+        self,
+        x_t,
+        prev_chunk_left_over,
+        inference_delay,
+        time,
+        original_denoise_step_partial,
+        execution_horizon=None,
+    ) -> Tensor:
+        
+        tau = 1 - time
+
+        if len(prev_chunk_left_over.shape) < 3:
+            # Add batch dimension
+            prev_chunk_left_over = prev_chunk_left_over.unsqueeze(0)
+
+        if execution_horizon > prev_chunk_left_over.shape[1]:
+            execution_horizon = prev_chunk_left_over.shape[1]
+
+        action_chunk_size = x_t.shape[1]
+        # Instead of static slice assignment which breaks dynamic shapes, we use F.pad.
+        # This allows ONNX to export a dynamic Pad operator that adapts to prev_chunk_left_over's actual length.
+        # We only pad the length dimension (dim=1).
+        
+        curr_len = prev_chunk_left_over.shape[1]
+        pad_len = action_chunk_size - curr_len
+        
+        if pad_len > 0:
+            # F.pad format: (pad_last_dim_left, pad_last_dim_right, pad_2nd_last_dim_left, pad_2nd_last_dim_right)
+            # We want to pad dim 1 (length), which is the 2nd last dim.
+            # dim 2 (action_dim) gets (0, 0)
+            # dim 1 (len) gets (0, pad_len) -> pad right side
+            prev_chunk_left_over = torch.nn.functional.pad(
+                prev_chunk_left_over, 
+                pad=(0, 0, 0, pad_len), 
+                mode='constant', 
+                value=0
+            )
+
+        # Also pad the action dimension (dim 2) if it's smaller than model's max_action_dim
+        # This allows exporting with dynamic/smaller inputs (e.g. from dataset) while model state is fixed size.
+        curr_action_dim = prev_chunk_left_over.shape[2]
+        max_action_dim = x_t.shape[2] # x_t is noise/action with max_action_dim
+        
+        if curr_action_dim < max_action_dim:
+            pad_action_dim = max_action_dim - curr_action_dim
+            prev_chunk_left_over = torch.nn.functional.pad(
+            prev_chunk_left_over,
+            pad=(0, pad_action_dim), # (pad_last_dim_left, pad_last_dim_right) = (0, pad_action_dim)
+            mode='constant',
+            value=0
+            )
+
+        # Use helper function to compute prefix weights for input tensors
+        weights = (
+            self.get_prefix_weights(inference_delay, execution_horizon, action_chunk_size)
+            .to(x_t.device)
+            .unsqueeze(0)
+            .unsqueeze(-1)
+        )
+        v_t = original_denoise_step_partial(x_t)
+
+        x1_t = x_t - time * v_t  # noqa: N806
+        err = (prev_chunk_left_over - x1_t) * weights
+        correction = err
+
+        max_guidance_weight = torch.as_tensor(self.rtc_processor.rtc_config.max_guidance_weight)
+        tau_tensor = torch.as_tensor(tau)
+        squared_one_minus_tau = (1 - tau_tensor) ** 2
+        inv_r2 = (squared_one_minus_tau + tau_tensor**2) / (squared_one_minus_tau)
+        c = torch.nan_to_num((1 - tau_tensor) / tau_tensor, posinf=max_guidance_weight)
+        guidance_weight = torch.nan_to_num(c * inv_r2, posinf=max_guidance_weight)
+        guidance_weight = torch.minimum(guidance_weight, max_guidance_weight)
+
+        result = v_t - guidance_weight * correction
+
+        return result
+
+    
+    def get_prefix_weights(self, start, end, total):
+        # Helper function to compute prefix weights when inputs are tensors
+        import math
+        # Ensure inputs are tensors for proper min/max operations if they aren't already
+        if not isinstance(start, torch.Tensor):
+            start = torch.tensor(start)
+        if not isinstance(end, torch.Tensor):
+            end = torch.tensor(end)
+
+        start = torch.minimum(start, end)
+
+        # This implementation supports both scalar and tensor inputs for start/end
+        # significantly simplifying the logic and making it ONNX-export friendly.
+        # It replaces the previous piecewise construction (ones + linspace + zeros)
+        # with a unified linear decay formula clamped to [0, 1].
+
+        # Create an index grid [0, 1, 2, ..., total-1]
+        idx = torch.arange(total, device=start.device, dtype=torch.float32)
+
+        # Safe denominator (end - start + 1), ensures no division by zero
+        denom = (end - start + 1).float()
+
+        # Linear decay formula:
+        # When idx <= start: (end - idx) >= (end - start) -> value >= (end-start)/denom ~ 1.0
+        # When idx >= end:   (end - idx) <= 0             -> value <= 0.0
+        weights = (end - idx) / denom
+
+        # Clamp to valid range [0, 1]
+        weights = torch.clamp(weights, min=0.0, max=1.0)
+
+        if self.rtc_processor.rtc_config.prefix_attention_schedule == RTCAttentionSchedule.EXP:
+                weights = weights * (torch.exp(weights) - 1).div(math.e - 1)
+        elif self.rtc_processor.rtc_config.prefix_attention_schedule != RTCAttentionSchedule.LINEAR:
+                pass
+        else:
+            raise NotImplementedError(f"Unimplemented prefix attention schedule: {self.rtc_config.prefix_attention_schedule}")
+        return weights
+
+inference_model = Pi05InferenceRTCWrapper(policy)
