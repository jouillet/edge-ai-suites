+from lerobot.configs.types import RTCAttentionSchedule
+from lerobot.policies.rtc.configuration_rtc import RTCConfig
+from lerobot.policies.rtc.modeling_rtc import RTCProcessor
+import torch
+from lerobot.policies.pi05.modeling_pi05 import PI05Policy, make_att_2d_masks
+import os
+import numpy as np
+from torch import Tensor
+import openvino as ov
+import argparse
+import json
+import tempfile
+from pathlib import Path
+from lerobot.configs.policies import PreTrainedConfig
+from lerobot.datasets.lerobot_dataset import LeRobotDataset
+from lerobot.policies.factory import make_pre_post_processors
+from lerobot.utils.constants import ACTION, OBS_LANGUAGE_TOKENS, OBS_LANGUAGE_ATTENTION_MASK
+
+parser = argparse.ArgumentParser(description="Convert PyTorch Pi05Policy to ONNX and OpenVINO IR")
+parser.add_argument("--camera_num", "-c", type=int, default=4, help="Batch size for image input/number of cameras")
+parser.add_argument("--torch_dir", type=str, default="lerobot/pi05_base", help="Path to the pretrained PyTorch model")
+parser.add_argument("--dataset_path", type=str, default=None, help="Path to local LeRobot dataset for real inputs")
+parser.add_argument("--onnx_output_dir", type=str, default="pi05_rtc_onnx", help="Path to save the ONNX model")
+parser.add_argument("--ov_output_dir", type=str, default="pi05_rtc_lerobot_ov_ir", help="Path to save the OpenVINO IR model")
+parser.add_argument("--compress_int8", action="store_true", help="Whether to compress models to INT8")
+parser.add_argument("--save_fp32", action="store_true", help="Whether to save OpenVINO model in FP32 format (FP16 by default)")
+parser.add_argument("--override", action="store_true", help="Whether to override existing files")
+
+args = parser.parse_args()
+
+# -----------------------------
+# Load PyTorch policy
+# -----------------------------
+print(f"LOADING MODEL from {args.torch_dir}")
+
+# Handle extra keys in config that might cause issues (similar to eval_aloha.py)
+config_path = Path(args.torch_dir) / "config.json"
+policy_cfg = None
+
+if config_path.exists():
+    with open(config_path, "r") as f:
+        cfg_dict = json.load(f)
+    
+    # "type" is a property in PreTrainedConfig, not a field, so draccus fails if it's in the json
+    # when loading the subclass directly. However, PreTrainedConfig.from_pretrained REQUIRES "type".
+    # so we must leave it if we use PreTrainedConfig.from_pretrained.
+    invalid_keys = ["use_peft", "freeze_vision_encoder", "train_expert_only"]
+    dirty = False
+    for k in invalid_keys:
+        if k in cfg_dict:
+            del cfg_dict[k]
+            dirty = True
+            
+    if dirty:
+        print(f"Sanitizing config: removed deprecated keys {invalid_keys}")
+        with tempfile.TemporaryDirectory() as temp_dir:
+            temp_config_path = Path(temp_dir) / "config.json"
+            with open(temp_config_path, "w") as f:
